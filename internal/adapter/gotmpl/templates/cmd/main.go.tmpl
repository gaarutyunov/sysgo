{{ template "header" . }}
// main is the composition root for the {{ .App }} binary — the only place
// allowed to import {{ if .Multi }}every wired bounded context{{ else }}the bounded context{{ end }} and wire concrete adapters
// into ports. This scaffold is written once.
func main() {
	root := &cobra.Command{
		Use:   "{{ .App }}",
		Short: "{{ .App }} — composition root",
	}
	root.AddCommand(newServeCmd())
	if err := root.Execute(); err != nil {
		log.Fatal(err)
	}
}

