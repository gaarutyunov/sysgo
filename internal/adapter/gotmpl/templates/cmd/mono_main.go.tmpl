// dependencies and start your servers.
func newServeCmd() *cobra.Command {
	return &cobra.Command{
		Use:   "serve",
		Short: "Start the {{ .App }} application",
		RunE: func(cmd *cobra.Command, _ []string) error {
{{- range .Contexts }}
			// TODO: wire the {{ .Name }} context{{ if .Inject }} — build it with inject{{ .Inject }}() once wire_gen.go exists{{ end }}.
{{- end }}
			return nil
		},
	}
}
