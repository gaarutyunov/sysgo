{{ template "header" . }}
// main is the composition root for the {{ .App }} application. It is the only
// place allowed to import every bounded context and wire concrete adapters into
// ports — here via each context's wire ProviderSet. This scaffold is written
// once.
func main() {
	root := &cobra.Command{
		Use:   "{{ .App }}",
		Short: "{{ .App }} — composition root wiring all bounded contexts",
	}
	root.AddCommand(newServeCmd())
	if err := root.Execute(); err != nil {
		log.Fatal(err)
	}
}

// newServeCmd starts the application. Run `wire ./...` to generate wire_gen.go
